<plugin id="outsystems-universal-links-wrapper" version="1.0.0"
        xmlns="http://apache.org/cordova/ns/plugins/1.0"
        xmlns:android="http://schemas.android.com/apk/res/android">


    <name>OutSystems Universal Links Wrapper</name>
    <description>Wrapper to inject universal link config for OutSystems</description>
    <license>MIT</license>


    <!-- Bundled deeplinks plugin (forked for MABS 12 / Node 20 compatibility) -->

    <!-- JavaScript -->
    <js-module name="universalLinks" src="deeplinks/www/universal_links.js">
        <clobbers target="universalLinks"/>
    </js-module>

    <!-- Deeplinks hooks -->
    <hook src="deeplinks/hooks/beforePluginInstallHook.js" type="before_plugin_install" />
    <hook src="deeplinks/hooks/afterPrepareHook.js" type="after_prepare" />

    <preference name="UL_HOST" default="" />
    <preference name="UL_EVENT" default="" />
    <preference name="UL_SCHEME" default="" />
    <preference name="UL_PATHS" default="" />
        
 
    <!-- iOS:  injects universal-links for only for ios - working -->
    <platform name="ios">
        <!-- Deeplinks iOS hook -->
        <hook src="deeplinks/hooks/iosBeforePrepareHook.js" type="before_prepare" />

        <!-- Register native plugin -->
        <config-file parent="/*" target="config.xml">
            <feature name="UniversalLinks">
                <param name="ios-package" value="CULPlugin"/>
                <param name="onload" value="true"/>
            </feature>
        </config-file>

        <!-- Objective-C sources -->
        <source-file src="deeplinks/src/ios/CULPlugin.m"/>
        <header-file src="deeplinks/src/ios/CULPlugin.h"/>

        <source-file src="deeplinks/src/ios/AppDelegate+CULPlugin.m"/>
        <header-file src="deeplinks/src/ios/AppDelegate+CULPlugin.h"/>

        <source-file src="deeplinks/src/ios/JS/CDVPluginResult+CULPlugin.m" target-dir="JS/"/>
        <header-file src="deeplinks/src/ios/JS/CDVPluginResult+CULPlugin.h" target-dir="JS/"/>

        <source-file src="deeplinks/src/ios/JS/CDVInvokedUrlCommand+CULPlugin.m" target-dir="JS/"/>
        <header-file src="deeplinks/src/ios/JS/CDVInvokedUrlCommand+CULPlugin.h" target-dir="JS/"/>

        <source-file src="deeplinks/src/ios/Model/CULHost.m" target-dir="Model/"/>
        <header-file src="deeplinks/src/ios/Model/CULHost.h" target-dir="Model/"/>

        <source-file src="deeplinks/src/ios/Model/CULPath.m" target-dir="Model/"/>
        <header-file src="deeplinks/src/ios/Model/CULPath.h" target-dir="Model/"/>

        <source-file src="deeplinks/src/ios/Parser/XML/CULXmlTags.m" target-dir="Parser/XML/"/>
        <header-file src="deeplinks/src/ios/Parser/XML/CULXmlTags.h" target-dir="Parser/XML/"/>

        <source-file src="deeplinks/src/ios/Parser/XML/CULConfigXmlParser.m" target-dir="Parser/XML/"/>
        <header-file src="deeplinks/src/ios/Parser/XML/CULConfigXmlParser.h" target-dir="Parser/XML/"/>

        <source-file src="deeplinks/src/ios/Parser/JSON/CULConfigJsonParser.m" target-dir="Parser/JSON/"/>
        <header-file src="deeplinks/src/ios/Parser/JSON/CULConfigJsonParser.h" target-dir="Parser/JSON/"/>

        <source-file src="deeplinks/src/ios/Utils/NSBundle+CULPlugin.m" target-dir="Utils/"/>
        <header-file src="deeplinks/src/ios/Utils/NSBundle+CULPlugin.h" target-dir="Utils/"/>

        <config-file target="config.xml" parent="/*">
                <universal-links>
                    <host event="$UL_EVENT" name="$UL_HOST" scheme="$UL_SCHEME">
                       $UL_PATHS
                    </host>
                </universal-links>
            </config-file>

            <edit-config
                file="**/Entitlements-Release.plist"
                mode="merge"
                target="com.apple.developer.associated-domains">
                <array>
                    <string>applinks:$UL_HOST</string>
                </array>
            </edit-config>        
            
            <edit-config
                file="**/Entitlements-Debug.plist"
                mode="merge"
                target="com.apple.developer.associated-domains">
                <array>
                    <string>applinks:$UL_HOST</string>
                </array>
            </edit-config>
            
    </platform>

